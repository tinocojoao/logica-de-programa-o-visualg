algoritmo "semnome"
var
   N, C, TotN: inteiro
inicio
   C <- 1
   TotN <- 0
   repita
      Escreva("Digite um numero: ")
      leia(n)
      se (N <0 ) entao
         TotN <- Totn + 1
      fimse
      C <- C + 1
   ate(C > 5)
   Escreval("Foram digitados ", TotN, " valores negativos.")
fimalgoritmo